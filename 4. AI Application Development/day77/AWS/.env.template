# Copy this file to .env and fill in local/AWS-specific values.
# Do not commit .env.

EC2_PUBLIC_IP=<EC2 퍼블릭 IP>
EC2_USER=ubuntu
SSH_KEY_PATH=<로컬 pem 키 경로>

EC2_PROJECT_PATH=/home/ubuntu/DjangoProject
DOCKER_CONTAINER=django-dev
DOCKER_PROJECT_PATH=/workspace
DJANGO_SERVICE=django-gunicorn
WEB_SERVICE=nginx

USE_RDS_DATABASE=1
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<RDS 비밀번호>
DB_HOST=<RDS 엔드포인트>
DB_PORT=5432
DB_SSLMODE=require

AWS_STORAGE_BUCKET_NAME=<S3 버킷명>
AWS_S3_REGION_NAME=ap-northeast-2
