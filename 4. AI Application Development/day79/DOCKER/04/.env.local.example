DJANGO_SECRET_KEY=<로컬용 아무 문자열, python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"로 생성>
DJANGO_DEBUG=true

DB_NAME=namingdb
DB_USER=namingadmin
DB_PASSWORD=localtest1234
DB_HOST=postgres-local

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localtest1234
NEO4J_DATABASE=neo4j

OPENAI_API_KEY=<팀 공유 API 키>
LAW_API_KEY=<팀 공유 API 키>
URIMALSAM_API_KEY=<팀 공유 API 키>

# USE_S3, DB_SSL_REQUIRE는 로컬에서는 비워두거나 넣지 않는다 (운영 .env에만 true로 설정)
